page {
  background: #f6f9ff;
  padding: 60rpx 0; /* 左右取消padding，只用table自身margin */
  margin: 0;
}
.stat-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 60rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #222;
  text-align: center;
}
/* 复刻index.table-box：左右20rpx外边距，限制宽度不贴边 */
.stat-table {
  margin: 0 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #1677ff;
  border-radius: 12rpx;
  overflow: hidden;
}
.table-row {
  display: flex;
  width: 100%;
}
.stat-head {
  background: #1677ff;
}
.stat-td {
  width: 33.33%;
  padding: 20rpx 8rpx; /* 缩小单元格内边距，防止内容撑宽 */
  text-align: center;
  font-size: 28rpx;
  border-right: 1rpx solid #e0ebfa;
  border-bottom: 1rpx solid #e0ebfa;
  box-sizing: border-box;
}
.stat-head .stat-td {
  color: #fff;
  font-weight: bold;
}
/* 最右侧列保留竖边框，闭合表格四边 */
.stat-td:last-child {
  border-right: 1rpx solid #e0ebfa;
}
.back-btn {
  margin: 0 20rpx; /* 按钮和表格左右对齐20rpx边距 */
  width: calc(100% - 40rpx);
  height: 80rpx;
  background: #1677ff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
}